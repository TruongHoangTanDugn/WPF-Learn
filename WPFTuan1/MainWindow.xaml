<Window x:Class="WPFTuan1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFTuan1"
        mc:Ignorable="d"
        Title="MainWindow" Background="CornflowerBlue" Height="450" Width="800">
    <Grid>
        <Label Content="Login" FontStretch="UltraCondensed" FontFamily="VNI-Bodon-Poster" FontSize="30" Foreground="AntiqueWhite" HorizontalAlignment="Left" Margin="290,45,0,0" VerticalAlignment="Top" Height="58" Width="110"/>

        <Label Content="Email"  HorizontalAlignment="Left" FontFamily=".VnArabia" Foreground="AntiqueWhite" Margin="289,90,0,0" VerticalAlignment="Top"/>
        <TextBox HorizontalAlignment="Center" Margin="0,121,0,0" FontFamily=".VnArabia" TextWrapping="Wrap" Text="username@gmail.com" Foreground="LightGray" VerticalAlignment="Top" Width="222"/>

        <Label Content="Password" Foreground="AntiqueWhite" FontFamily=".VnArabia" HorizontalAlignment="Left" Margin="290,156,0,0" VerticalAlignment="Top"/>
        <TextBox HorizontalAlignment="Center" Margin="0,182,0,0" TextWrapping="Wrap" FontFamily=".VnArabia" Text="Password" Foreground="LightGray" VerticalAlignment="Top" Width="221"/>
        <Button Content="Forget Password?" BorderBrush="Transparent" Foreground="AntiqueWhite" Background="CornflowerBlue" HorizontalAlignment="Left" Margin="290,0,0,0" FontFamily=".VnArabia" VerticalAlignment="Center" Click="Button_Click"/>

        
        <Button Content="Sign in" FontFamily=".VnArabia" FontSize="20" BorderBrush="Transparent" Foreground="AntiqueWhite" Background ="MidnightBlue" HorizontalAlignment="Left" Margin="290,244,0,0" VerticalAlignment="Top" Width="236" Click="Button_Click_1"/>
        <TextBox HorizontalAlignment="Left" Margin="356,280,0,0" TextWrapping="Wrap" Text="Or continue with" Foreground="AntiqueWhite" Background="CornflowerBlue" VerticalAlignment="Top" BorderBrush="Transparent" Width="120"/>
        <Label Content="Don't have an account?" HorizontalAlignment="Left" Margin="289,386,0,0" VerticalAlignment="Top"/>
        <Button Content="Register for free" Foreground="AntiqueWhite"  Background="CornflowerBlue" HorizontalAlignment="Left" Margin="423,389,0,0" VerticalAlignment="Top"/>


    </Grid>
</Window>
