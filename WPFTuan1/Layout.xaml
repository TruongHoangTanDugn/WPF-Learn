<Window x:Class="WPFTuan1.Layout"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFTuan1"
        mc:Ignorable="d"
        Title="Layout" Height="450" Width="800">
    <Grid>
        <StackPanel Margin="15" VerticalAlignment="Top" Height="Auto">
            <Label Content="Chi tiết giao dịch" VerticalAlignment="Center" FontSize="18"  Height="37" Width="144" HorizontalAlignment="Left"/>
            <StackPanel Orientation="Vertical">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Stretch" Height="Auto">
                    <StackPanel Orientation="Vertical" Width="235.5" Height="Auto">
                        <Label Content="Khách hàng"></Label>
                        <Label Content="Nguyễn Thị Mai"></Label>
                    </StackPanel>
                    <StackPanel Orientation="Vertical" Width="235.5" Height="Auto">
                        <Label Content="Nhà tiên tri"></Label>
                        <Label Content="Minh Tuệ"></Label>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </StackPanel>

    </Grid>
</Window>
