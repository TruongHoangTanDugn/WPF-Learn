<Window x:Class="WPFTuan1.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFTuan1"
        mc:Ignorable="d"
        Title="Window1" Background="DarkSlateBlue"  Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="29*"/>
            <ColumnDefinition Width="371*"/>
        </Grid.ColumnDefinitions>
        <Grid Grid.Column="1" Background="MediumSlateBlue" Margin="196,66,254,66">
            <Label Content="Sign up" FontSize="25" FontFamily=".VnArabia" HorizontalAlignment="Center" Margin="0,10,0,0" VerticalAlignment="Top"/>
            <TextBox HorizontalAlignment="Center" Margin="0,108,0,0" FontFamily=".VnArabia" TextWrapping="Wrap" Text="Email" Foreground="LightGray" VerticalAlignment="Top" Width="220" Height="19"/>
            <TextBox HorizontalAlignment="Center" FontFamily=".VnArabia" TextWrapping="Wrap" Text="Password" Foreground="LightGray" VerticalAlignment="Center" Width="220" Height="19"/>
            <TextBox HorizontalAlignment="Center" Margin="0,181,0,0" FontFamily=".VnArabia" TextWrapping="Wrap" Text="Confirm Password" Foreground="LightGray" VerticalAlignment="Top" Width="220" Height="19"/>
            <Button Content="Sign In" FontFamily=".VnArabia" Foreground="AntiqueWhite" Background="DarkSlateBlue" HorizontalAlignment="Left" Margin="49,232,0,0" VerticalAlignment="Top" Height="26" Width="190"/>
        </Grid>
        <TextBox HorizontalAlignment="Left" Margin="232,140,0,0" FontFamily=".VnArabia" TextWrapping="Wrap" Text="User name" Foreground="LightGray" VerticalAlignment="Top" Width="220" Height="19" Grid.Column="1"/>
    </Grid>
</Window>
