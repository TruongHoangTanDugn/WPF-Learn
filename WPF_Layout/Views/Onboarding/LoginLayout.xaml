<Page x:Class="WPF_Layout.LoginLayout"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:local="clr-namespace:WPF_Layout"
      mc:Ignorable="d"
      Title="LoginLayout"
      Background="CornflowerBlue"
      MinHeight="45"
      MinWidth="800">

    <Grid Background="#6495ED">
        <Viewbox Stretch="Uniform">
            <Grid Width="Auto" Height="Auto">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="1" Grid.Column="1">
                    <Label Content="👱Login👨‍🦳" FontSize="40" HorizontalAlignment="Center" Foreground="White" FontFamily="VNI-Bodon-Poster"/>

                    <TextBlock Text="Email" Foreground="White"/>
                    <TextBox x:Name="txtEmail" Height="35" VerticalContentAlignment="Center" Padding="5"/>

                    <TextBlock Text="Password" Foreground="White"/>
                    <PasswordBox x:Name="txtPassword" Height="35" VerticalContentAlignment="Center" Padding="5"/>
                    <Button x:Name="buttonForgetPass"
                        Content="Forget Password?"
                        BorderBrush="Transparent"
                        Foreground="AntiqueWhite"
                        Background="CornflowerBlue"
                        FontFamily=".VnArabia"
                        Click="ForgetPassButton"
                        ToolTip="Recover your password"
                        AutomationProperties.Name="Forget Password"
                        HorizontalAlignment="Left"
                        Padding="0,5" />
                    <Button x:Name="buttonSignIn" Content="Sign in" Background="MidnightBlue" Foreground="White" Height="45" FontWeight="Bold" Click="SignInButton"/>

                    <TextBlock Text="Or continue with" Foreground="White" HorizontalAlignment="Center"/>
                    <!-- Register Section -->

                    

                    </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                            <TextBlock Text="Don't have an account?"
                               Foreground="AntiqueWhite"
                               FontFamily=".VnArabia"
                               VerticalAlignment="Center"
                               />

                            <Button x:Name="buttonRegister"
                                Content="Register for free"
                                Foreground="AntiqueWhite"
                                Background="CornflowerBlue"
                                BorderBrush="Transparent"
                                FontFamily=".VnArabia"
                                Click="RegisterButton"
                                ToolTip="Create a new account"
                                AutomationProperties.Name="Register for free"
                                Padding="8,5"
                                />
                        </StackPanel>
            </Grid>
        </Viewbox>
    </Grid>
</Page>
