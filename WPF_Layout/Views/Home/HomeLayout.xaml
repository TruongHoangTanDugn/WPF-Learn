<Page x:Class="WPF_Layout.Views.Home.HomeLayout"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WPF_Layout.Views.Home"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="HomeLayout">

    <Grid Background="CadetBlue">
        <StackPanel Orientation="Vertical">
            <Grid Height="45" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" x:Name = "HomeLabel" FontFamily=".VnCommercial ScriptH" Height="Auto" HorizontalAlignment="Center" FontSize="50" Content = "🏚️Home"></Label>
                <Button Grid.Column="1" Content="My Network" BorderBrush="Transparent" FontSize="14" Background="CadetBlue" FontFamily=".VnBodoni"></Button>
                <Button Grid.Column="2" Content="Jobs" BorderBrush="Transparent" FontSize="14" Background="CadetBlue" FontFamily=".VnBodoni"></Button>
                <Button Grid.Column="4" x:Name = "buttonLogOut" Content = "Log out" Background="IndianRed" FontFamily=".VnBodoni"  Height="45" VerticalAlignment="Top" Click="LogOutButton"></Button>
                <Button Grid.Column="5" x:Name = "buttonDeleteAcc" Content = "Delete account" FontFamily=".VnBodoni" Background="OrangeRed" Click="DeleteAccountButton"></Button>

            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="4*"/>
                    <RowDefinition Height="4*"/>
                    <RowDefinition Height="4*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
            </Grid>
        </StackPanel>

    </Grid>
</Page>
