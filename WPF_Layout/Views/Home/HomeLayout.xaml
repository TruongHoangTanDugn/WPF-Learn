<Page x:Class="WPF_Layout.Views.Home.HomeLayout"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WPF_Layout.Views.Home"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="HomeLayout">

    <Grid Background="CadetBlue">
        <StackPanel Orientation="Vertical">
            <Grid Height="45" VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label Grid.Column="0" x:Name = "HomeLabel" FontFamily=".VnCommercial ScriptH"  HorizontalAlignment="Center" FontSize="25" Content = "Home"></Label>
                <Button Grid.Column="1" Content="My Network" BorderBrush="Azure"  FontFamily=".VnBodoni"></Button>
                <Button Grid.Column="2" Content="Jobs" FontFamily=".VnBodoni"></Button>
                <Button Grid.Column="4" x:Name = "buttonLogOut" Content = "Log out" FontFamily=".VnBodoni" Height="45" VerticalAlignment="Top" Click="LogOutButton"></Button>
                <Button Grid.Column="5" x:Name = "buttonDeleteAcc" Content = "Delete account" FontFamily=".VnBodoni" Click="DeleteAccountButton"></Button>

            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="50"/>
                </Grid.RowDefinitions>
            </Grid>
        </StackPanel>

    </Grid>
</Page>
