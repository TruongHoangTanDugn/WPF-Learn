<Page x:Class="WPF_Layout.Views.Home.HomeLayout"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:WPF_Layout.Views.Home"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="HomeLayout">

    <Grid Background="White">
        <StackPanel Orientation="Vertical" Margin="5" VerticalAlignment="Stretch">
            <StackPanel Orientation="Horizontal">
                <Label Content="Home" FontSize="25" FontWeight="Bold" Foreground="Black" BorderBrush="Transparent"></Label>
                <Button Content="Log Out" HorizontalAlignment="Right"></Button>
            </StackPanel>
            <Label Content="Welcome to the Home Page!" HorizontalAlignment="Center" Foreground="DarkSlateGray" FontSize="20"></Label>
        </StackPanel>

    </Grid>
</Page>
